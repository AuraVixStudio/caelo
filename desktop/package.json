{
  "name": "grok-desktop",
  "version": "0.0.1",
  "description": "Grok Desktop — powłoka Electron (frontend) dla aplikacji Grok w stylu Claude Code / Codex",
  "author": "grooverpty",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "preview:web": "vite --config vite.preview.config.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack:sidecar": "powershell -ExecutionPolicy Bypass -File ../build_sidecar.ps1",
    "dist": "npm run build && electron-builder --win",
    "dist:full": "npm run pack:sidecar && npm run build && electron-builder --win"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tailwindcss/vite": "^4.3.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.40",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
